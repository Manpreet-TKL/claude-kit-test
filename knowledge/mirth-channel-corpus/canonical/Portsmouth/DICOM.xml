            <com.mirth.connect.plugins.javascriptstep.JavaScriptStep version="4.4.2">
              <name>Extract identifier_type and institution_id from Local AET</name>
              <sequenceNumber>14</sequenceNumber>
              <enabled>true</enabled>
              <script>// Regex pattern for matching a patient_identifier_type.unique_string
var regex = /(local|global)-(\d+)-(\d+)/i;

// Set default values from configuration map or default to LOCAL-1-0
var configPIDT = configurationMap.get(&apos;defaultPatientIdentifierType&apos;);
var identifier_type = (typeof configPIDT !== &apos;undefined&apos; &amp;&amp; configPIDT !== null) ? configPIDT : &apos;LOCAL-1-0&apos;;
var institution_id = identifier_type.match(regex)[2]; //get deafult institution_id

var str = $(&apos;local_AET&apos;);
var result = str.match(regex);

// If a result was found, use it as the identifire_type
if (typeof result !== &apos;undefined&apos; &amp;&amp; result !== null) {
	identifier_type = result[0].toUpperCase();
	institution_id = result[2]; // First nuber after LOCAL|GLOBAL-
}

// Add final values to the channelMap.
channelMap.put(&apos;identifier_type&apos;, identifier_type);
channelMap.put(&apos;institution_id&apos;, institution_id);</script>
            </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
            <com.mirth.connect.plugins.javascriptstep.JavaScriptStep version="4.4.2">
              <name>Set source platform tag based on AET</name>
              <sequenceNumber>15</sequenceNumber>
              <enabled>true</enabled>
              <script>// source_platform works around some issues with particular ImageNET outputs by giving the PayloadProcessor a hint
// it may also be used for linking events with intgratiosn to PACS such as imagenet, forum
var source_platform = &apos;generic&apos;;

if (
	$(&apos;remote_AET&apos;).toLowerCase().contains(&apos;imagenet&apos;) 
		|| $(&apos;local_AET&apos;).toLowerCase().contains(&apos;imagenet&apos;)
)
{
	source_platform = &apos;imagenet&apos;;
} else if (
	$(&apos;remote_AET&apos;).toLowerCase().contains(&apos;forum&apos;) 
		|| $(&apos;local_AET&apos;).toLowerCase().contains(&apos;forum&apos;)
)
{
	source_platform = &apos;forum&apos;;
} 

channelMap.put(&apos;source_platform&apos;, source_platform);</script>
            </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
            <com.mirth.connect.plugins.javascriptstep.JavaScriptStep version="4.4.2">
              <name>Remove the IOLMaster Import destination if device is not a Zeiss IOL Master</name>
              <sequenceNumber>16</sequenceNumber>
              <enabled>true</enabled>
              <script>const supportedSOPUIDs = [&apos;1.2.840.10008.5.1.4.1.1.104.1&apos;, &apos;1.2.840.10008.5.1.4.1.1.7.4&apos;];
const sopClassUIDString = String($(&apos;SOP_Class_UID&apos;));

if (
	$(&apos;Device_Manufacturer&apos;).toLowerCase().indexOf(&apos;zeiss&apos;) == -1
	|| $(&apos;Device_Model_Name&apos;).toLowerCase().indexOf(&apos;iolmaster&apos;) == -1
	|| !supportedSOPUIDs.includes(sopClassUIDString)
)
{
	// IOL Master Importer destination must be destination ID 1
	destinationSet.remove([1]);
}</script>
