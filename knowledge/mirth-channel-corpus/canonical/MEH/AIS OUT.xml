            <script>// Parse the outer XML to access the Body
var innerXml = new XML(msg).Body.toString().replace(/&amp;lt;/g, &apos;&lt;&apos;).replace(/&amp;gt;/g, &apos;&gt;&apos;);

// Parse the decoded inner XML
var xmlDoc = new XML(innerXml);

// Get the current date and time formatted as YYYYMMDDHHMM
var now = new Date();
var formattedDate = now.getFullYear().toString() +
                    (now.getMonth() + 1).toString().padStart(2, &apos;0&apos;) +
                    now.getDate().toString().padStart(2, &apos;0&apos;);

// Initialize an array to hold the output
var outputArray = [];

// Loop through each AISFlag and create the desired output
for each (var aisFlag in xmlDoc..AISFlag) {
    outputArray.push(&quot;IAM|1||&quot; + aisFlag.Value.toString() + &quot;|||U|||||||&quot; + formattedDate);
}

// Set the connector response
channelMap.put(&apos;IAMSection&apos;,outputArray.join(&apos;\r&apos;));</script>
