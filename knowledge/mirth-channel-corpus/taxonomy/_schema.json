{
  "description": "Per-channel classification record emitted by each Phase 2 taxonomy slice. One JSON array per instance batch at taxonomy/_slices/<batch>.json.",
  "category_vocabulary": [
    "PAS Inbound (HL7 -> PASAPI)",
    "PAS Outbound (query/response to remote PAS)",
    "PAS Query / PDQ (MPI SOAP)",
    "DICOM Ingestion",
    "IOLMaster / Biometry Import",
    "Document / Correspondence Ingestion",
    "Document / Correspondence Outbound",
    "PayloadProcessor Submission",
    "AIS Integration",
    "Routing / Utility",
    "Other (propose a name)"
  ],
  "record": {
    "channel_id": "string",
    "channel_name": "string",
    "instance": "string",
    "source_file": "string (corpus-relative)",
    "canonical_path": "string",
    "category": "one of category_vocabulary",
    "functional_purpose": "1-2 sentences, what it does",
    "business_process": "clinical/operational process supported",
    "source_system": "upstream system (PAS/PACS/device/file drop/...)",
    "destination_systems": ["OpenEyes PASAPI", "PayloadProcessor", "remote PAS", "file share", "..."],
    "source_connector": {"type": "transportName", "port": "or null"},
    "destination_connectors": [{"name": "", "type": "transportName", "endpoint": "host/url/path (redacted ok)"}],
    "protocol": "MLLP / HTTP / HTTPS / DICOM / SOAP / file / ...",
    "message_format": "HL7v2 / DICOM / JSON / XML / PDF / ...",
    "hl7_version": "e.g. 2.4 or null",
    "hl7_message_types": ["ADT", "SIU", "..."],
    "hl7_trigger_events": ["A01", "A28", "S12", "..."],
    "ack_behaviour": "how ACK/NACK is produced, or null",
    "oe_endpoints": ["PASAPI/V2/Patient", "/api/v1/Document/create", "..."],
    "oe_api_versions": ["V1", "V2", "V3", "api/v1"],
    "auth_method": "HTTP Basic / none / ...",
    "main_filters": ["short description per filter rule"],
    "main_transformer_stages": ["ordered short descriptions"],
    "depends_on": ["configurationMap:defaultPatientIdentifierType", "channel:<name>", "..."],
    "error_handling": "short",
    "retry_behaviour": "queue on/off, retry policy",
    "queue_behaviour": "source/destination queueing",
    "logging": "what is logged; note any PII-in-log risk",
    "stateful": true,
    "safe_to_replay": true,
    "reusable_vs_client_specific": "reusable | client-specific | reusable-with-config",
    "evidence": [{"claim": "", "location": "connector/filter/transformer/script + line-ish", "confidence": "confirmed|inferred"}],
    "confidence": "confirmed|inferred"
  }
}
