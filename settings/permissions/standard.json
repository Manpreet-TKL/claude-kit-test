{
  "defaultMode": "acceptEdits",
  "allow": [
    "Read",
    "Edit",
    "Write",
    "Bash(npm *)",
    "Bash(npx *)",
    "Bash(git status)",
    "Bash(git diff *)",
    "Bash(git log *)",
    "Bash(ls *)",
    "Bash(cat *)",
    "Bash(grep *)",
    "mcp__atlassian",
    "mcp__github",
    "mcp__codex",
    "Bash(~/claude-kit/install.sh -l *)",
    "Bash(bash ~/claude-kit/install.sh -l *)"
  ],
  "ask": [
    "Bash"
  ],
  "deny": [
    "Bash(git push *)",
    "Bash(git commit *)",
    "Read(./.env)",
    "Read(./.env.*)",
    "Read(~/.ssh/**)"
  ]
}
