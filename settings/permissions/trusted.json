{
  "defaultMode": "dontAsk",
  "allow": [
    "Read",
    "Edit",
    "Write",
    "Bash",
    "mcp__atlassian",
    "mcp__github",
    "mcp__codex",
    "Bash(~/claude-kit/install.sh -l *)",
    "Bash(bash ~/claude-kit/install.sh -l *)"
  ],
  "deny": [
    "Bash(git push *)",
    "Bash(git commit *)",
    "Read(./.env)",
    "Read(./.env.*)",
    "Read(~/.ssh/**)",
    "Bash(rm -rf /*)",
    "Bash(rm -rf ~*)"
  ]
}
