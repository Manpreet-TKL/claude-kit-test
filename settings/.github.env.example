# GitHub credentials for the github-mcp-server stdio MCP server (READ-ONLY).
# Copy to settings/.github.env, fill in a fine-grained read-only PAT, then run:
#   ./install.sh -g -p standard -y
#
# .github.env is gitignored. This example file is safe to commit.
# Read-only is enforced by install.sh (GITHUB_READ_ONLY=1) and is NOT configurable here.

# Fine-grained PAT, read-only. Minimal repo permissions (read): Contents, Metadata,
# Pull requests, Issues. Must have access to the openeyes org's private repos.
GITHUB_PERSONAL_ACCESS_TOKEN=your-fine-grained-read-only-pat-here

# Optional: restrict exposed toolsets (comma-separated). Leave blank for the server
# default (context,issues,pull_requests,repos,users). e.g. repos,pull_requests,issues,actions
GITHUB_TOOLSETS=
