# Atlassian credentials for mcp-atlassian stdio MCP server.
# Copy to generated/.atlassian.env, fill in real values, then run:
#   ./install.sh -j -p standard -y          # Jira only
#   ./install.sh -c -p standard -y          # Confluence only
#   ./install.sh --with-atlassian -p standard -y   # both
#
# generated/.atlassian.env is gitignored (the whole generated/ folder is). This
# example file is safe to commit.

# --- Jira ---
JIRA_URL=https://openeyes.atlassian.net
JIRA_USERNAME=you@toukanlabs.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECTS_FILTER=TKLS,OE

# --- Confluence ---
# URL and credentials are usually the same as Jira on Atlassian Cloud.
CONFLUENCE_URL=https://openeyes.atlassian.net
CONFLUENCE_USERNAME=you@toukanlabs.com
CONFLUENCE_API_TOKEN=your-confluence-api-token-here
# Leave blank to allow all spaces.
CONFLUENCE_SPACES_FILTER=OPD
