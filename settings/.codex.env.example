# Codex agent defaults for the `codex mcp-server` stdio MCP server.
# Copy to generated/.codex.env, adjust if you like, then run:
#   ./install.sh -x -p standard -y
#
# generated/.codex.env is gitignored (the whole generated/ folder is). This example
# file is safe to commit. NOTE: there is NO secret here — Codex authenticates with
# your ChatGPT login (`codex login`, stored in ~/.codex), not a token in this kit.
#
# These values are baked into the server registration as `-c key=value` overrides,
# so every spawned agent inherits them. Edit + re-run `./install.sh -x -y` to change.

# Model the agents run. Default is the flagship (most capable). Leave it pointed at
# the current best; update when OpenAI ships the next one.
CODEX_MODEL=gpt-5.5

# Reasoning effort: minimal | low | medium | high | xhigh  (xhigh is model-dependent).
CODEX_REASONING_EFFORT=high

# Sandbox the agents' own shell runs in:
#   read-only           — no file writes (agents propose diffs only)
#   workspace-write     — writes within the cwd tree; network OFF (cannot git push)
#   danger-full-access  — no sandbox; throwaway container/VM only
CODEX_SANDBOX=workspace-write
