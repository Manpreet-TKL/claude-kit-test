{
  "mcpServers": {
    "atlassian": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "JIRA_URL",
        "-e", "JIRA_USERNAME",
        "-e", "JIRA_API_TOKEN",
        "-e", "JIRA_PROJECTS_FILTER",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "env": {
        "JIRA_URL": "__JIRA_URL__",
        "JIRA_USERNAME": "__JIRA_USERNAME__",
        "JIRA_API_TOKEN": "__JIRA_API_TOKEN__",
        "JIRA_PROJECTS_FILTER": "__JIRA_PROJECTS_FILTER__"
      }
    }
  }
}
